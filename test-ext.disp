(load "disp.lisp")

(define a (make-channel 0))   ; 无缓冲通道
(define b (make-channel 0))
(go (lambda () (sleep-ms 30) (send a 'from-a)))
(go (lambda () (sleep-ms 10) (send b 'from-b)))
(go (lambda ()
      (select
        ((recv a) (println "got from a: " it))
        ((recv b) (println "got from b: " it)))))
(event-loop)


(block nil
  (println "before return")
  (return "exited")
  (println "after return"))

(block outer
  (dolist (x '(1 2 3 4))
    (if (= x 3) (return-from outer 'found))
    (printf "x=%d\n" x))
  'not-found)


;; ========== 1. 测试通道关闭与 recv2 ==========
(define ch (make-channel 2))

;; 发送两个值后关闭通道
(go-func (lambda ()
      (send ch "hello")
      (send ch "world")
      (close-channel ch)
      (println "producer: channel closed")))

;; 接收端：使用 recv2 检测关闭状态
(go-func (lambda ()
      (block nil
        (while #t
          (let ((pair (recv2 ch)))
            (if (cdr pair)
              (begin
                (println "consumer: channel closed, exiting")
                (return))
              (println (string-append "consumer got: " (car pair)))))))))

;; 启动事件循环（运行 1 秒后退出，避免永久阻塞）
(go-func (lambda () (sleep-ms 1000) (println "timeout, exiting") (quit)))
(event-loop)
;; 期望输出：
;; consumer got: hello
;; consumer got: world
;; consumer: channel closed, exiting
;; timeout, exiting

;; ========== 2. 测试 select（多路复用） ==========
(define ch1 (make-channel 0))
(define ch2 (make-channel 0))
(define result (make-channel 0))

;; 生产者1：发送 1 后延迟
(go (lambda ()
      (send ch1 1)
      (println "producer1 sent 1")
      (send result 'done)))

;; 生产者2：延迟后发送 2
(go (lambda ()
      (sleep-ms 50)
      (send ch2 2)
      (println "producer2 sent 2")
      (send result 'done)))

;; 消费者：select 等待 ch1 或 ch2
(go (lambda ()
      (select
        ((recv ch1) 
         (println (string-append "selected ch1: " (string (it)))))
        ((recv ch2)
         (println (string-append "selected ch2: " (string (it)))))
        ((after 100)
         (println "timeout, no data")))
      (send result 'done)))

;; 等待所有协程结束（通过结果通道计数）
(define count 0)
(while (< count 3)
  (recv result)
  (set! count (+ count 1)))
(println "select test finished")
;; 期望输出（生产者2因延迟可能晚到，select 应选中 ch1）：
;; producer1 sent 1
;; selected ch1: 1
;; producer2 sent 2
;; select test finished

;; ========== 3. 测试 select 与 default 分支 ==========
(define ch (make-channel 0))
(select
  ((recv ch) (println "received: " it))
  (default (println "no data immediately")))
;; 期望输出：no data immediately

;; ========== 4. 测试非阻塞文件读写 ==========
;; 创建一个管道用于测试（或使用普通文件，但普通文件通常不阻塞）
;; 这里使用临时文件，但为了演示非阻塞，我们用一个命名管道或 socket。
;; 为简单，直接读写普通文件（通常不阻塞，但能演示基本调用）
(define f (fopen "test-nb.txt" "w+"))
(fwrite-nb f "Hello, non-blocking world!\n")
(fclose f)

(define f2 (fopen "test-nb.txt" "r"))
(define content (fread-nb f2))
(println content)
(fclose f2)
;; 期望输出："Hello, non-blocking world!"

;; ========== 5. 测试 select 与 after 超时 ==========
(define ch (make-channel 0))
(println "waiting for channel, but will timeout")
(select
  ((recv ch) (println "received: " it))
  ((after 200) (println "timeout after 200ms")))
;; 期望输出：timeout after 200ms

;; ========== 6. 测试 select 同时等待多个通道（哪个先就绪） ==========
(define a (make-channel 0))
(define b (make-channel 0))
(go (lambda () (sleep-ms 30) (send a 'from-a)))
(go (lambda () (sleep-ms 10) (send b 'from-b)))
(select
  ((recv a) (println "got from a: " it))
  ((recv b) (println "got from b: " it)))
;; 期望输出：got from b: from-b  （因为 b 的延迟更短）

(println "All tests completed.")
